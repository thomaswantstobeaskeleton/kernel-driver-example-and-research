<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Single source for mapper output name. Edit here - both kdmapper build and loader use it.
       kdmapper = default. IntelCpHDCP = benign name. -->
  <PropertyGroup>
    <MapperOutputName Condition="'$(MapperOutputName)' == ''">kdmapper</MapperOutputName>
  </PropertyGroup>
</Project>
